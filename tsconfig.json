{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "sourceMap": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "config/**/*",
    "fixtures/**/*",
    "pages/**/*",
    "tests/**/*",
    "types/**/*",
    "utils/**/*",
    "playwright.config.ts",
    "playwright.config.saucedemo.ts",
    "playwright.config.api.ts",
    "playwright.config.suites.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "reports",
    "test-results",
    "allure-results"
  ]
}
