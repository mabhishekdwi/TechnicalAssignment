{
  "name": "playwright-automation-framework",
  "version": "1.0.0",
  "description": "Advanced Playwright test framework with Allure reporting, API testing, and database utilities",
  "type": "module",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "test:report": "npx playwright show-report",
    "test:parallel": "npx playwright test --workers=4",
    "test:chrome": "npx playwright test --project='Desktop Chrome'",
    "test:firefox": "npx playwright test --project='Desktop Firefox'",
    "test:safari": "npx playwright test --project='Desktop Safari'",
    "test:edge": "npx playwright test --project='Desktop Edge'",
    "test:mobile": "npx playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:allbrowsers": "npx playwright test --project='Desktop Chrome' --project='Desktop Firefox' --project='Desktop Edge'",
    "allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "allure:serve": "allure serve ./allure-results",
    "type-check": "tsc --noEmit",
    "test:suites": "npx playwright test --config=playwright.config.suites.ts",
    "test:smoke": "npx playwright test --config=playwright.config.suites.ts --project=smoke",
    "test:sanity": "npx playwright test --grep @sanity",
    "test:critical": "npx playwright test --grep @critical",
    "test:regression": "npx playwright test --config=playwright.config.suites.ts --project=regression",
    "test:user-management": "npx playwright test --config=playwright.config.suites.ts --project=user-management",
    "test:ecommerce": "npx playwright test --config=playwright.config.suites.ts --project=ecommerce",
    "test:products": "npx playwright test --config=playwright.config.suites.ts --project=products",
    "test:checkout": "npx playwright test --config=playwright.config.suites.ts --project=checkout",
    "test:nightly": "npx playwright test --config=playwright.config.suites.ts --project=nightly",
    "test:cross-browser": "npx playwright test --config=playwright.config.suites.ts --project=cross-browser-chrome --project=cross-browser-firefox --project=cross-browser-safari",
    "test:signup": "npx playwright test tests/signup.spec.ts",
    "test:login": "npx playwright test tests/login.spec.ts",
    "test:products:spec": "npx playwright test tests/products.spec.ts",
    "test:cart": "npx playwright test tests/cart.spec.ts",
    "test:checkout:spec": "npx playwright test tests/checkout.spec.ts",
    "test:api": "npx playwright test tests/api-tests.spec.ts",
    "test:api:critical": "npx playwright test tests/api-tests.spec.ts --grep @critical",
    "test:api:negative": "npx playwright test tests/api-tests.spec.ts --grep @negative",
    "test:api:working": "npx playwright test tests/api-tests-working.spec.ts",
    "test:additional": "npx playwright test tests/additional-flows.spec.ts",

    "sd:test": "npx playwright test --config=playwright.config.saucedemo.ts",
    "sd:test:headed": "npx playwright test --config=playwright.config.saucedemo.ts --headed",
    "sd:test:smoke": "npx playwright test --config=playwright.config.saucedemo.ts --grep @smoke",
    "sd:test:regression": "npx playwright test --config=playwright.config.saucedemo.ts --grep @regression",
    "sd:test:e2e": "npx playwright test --config=playwright.config.saucedemo.ts --grep @e2e",
    "sd:test:login": "npx playwright test --config=playwright.config.saucedemo.ts tests/saucedemo/login.spec.ts",
    "sd:test:products": "npx playwright test --config=playwright.config.saucedemo.ts tests/saucedemo/products.spec.ts",
    "sd:test:checkout": "npx playwright test --config=playwright.config.saucedemo.ts tests/saucedemo/checkout.spec.ts",
    "sd:report": "npx playwright show-report reports/saucedemo-report",

    "api:test": "npx playwright test --config=playwright.config.api.ts",
    "api:test:smoke": "npx playwright test --config=playwright.config.api.ts --grep @smoke",
    "api:test:e2e": "npx playwright test --config=playwright.config.api.ts --grep @e2e",
    "api:test:auth": "npx playwright test --config=playwright.config.api.ts tests/api/auth.spec.ts",
    "api:test:get": "npx playwright test --config=playwright.config.api.ts tests/api/booking-get.spec.ts",
    "api:test:crud": "npx playwright test --config=playwright.config.api.ts tests/api/booking-create-update.spec.ts",
    "api:test:delete": "npx playwright test --config=playwright.config.api.ts tests/api/booking-delete.spec.ts",
    "api:report": "npx playwright show-report reports/api-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "@types/mysql": "^2.15.22",
    "@types/pg": "^8.10.9",
    "allure-commandline": "^2.25.0",
    "allure-playwright": "^2.15.1",
    "dotenv": "^17.2.3",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "mongodb": "^6.3.0",
    "mysql2": "^3.6.5",
    "pg": "^8.11.3",
    "xlsx": "^0.18.5"
  }
}
